# -*- makefile -*-

kernel.bin: DEFINES = -DUSERPROG -DFILESYS -DLEAKCHECK
KERNEL_SUBDIRS = threads devices lib lib/kernel userprog filesys
TEST_SUBDIRS = tests/userprog tests/filst tests/filesys/base
#tests/userprog/no-vm will only pass if page faults in kernel space are caught
#and treated as errors in userspace
GRADING_FILE = $(SRCDIR)/tests/userprog/Grading
SIMULATOR = --qemu
